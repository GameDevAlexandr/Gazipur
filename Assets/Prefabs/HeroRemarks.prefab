  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0e727a010166fa840a115d471e75743c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CharacterRemarks
  _cGroup: {fileID: 0}
  _remarkText: {fileID: 0}
  _remarks:
  - remark: "\u041F\u043E\u043A\u0430 \u0445\u0432\u0430\u0442\u0438\u0442, \u0430
      \u0442\u043E \u0441\u0435\u0442\u043A\u0430 \u0442\u0440\u0435\u0441\u043D\u0435\u0442"
    voice: {fileID: 0}
    isMultiRemark: 0
    remarkAnyTime: 
    voiceAnyTime: {fileID: 0}
    chance: 100
    showTime: 2
    type: 3
    isOneTime: 0
    hasBeen: 0
  - remark: "\u0412\u043E\u0442 \u0435\u0441\u043B\u0438 \u0431\u044B \u0443 \u043C\u0435\u043D\u044F
      \u0431\u044B\u043B\u0430 \u043E\u0442\u0432\u0435\u0440\u0442\u043A\u0430 \u0432\u043C\u0435\u0441\u0442\u043E
      \u043F\u0430\u043B\u044C\u0446\u0430... \u0417\u0430\u0447\u0435\u043C \u043D\u0443\u0436\u0435\u043D
      \u0431\u0435\u0437\u044B\u043C\u044F\u043D\u043D\u044B\u0439?"
    voice: {fileID: 0}
    isMultiRemark: 1
    remarkAnyTime: "\u0411\u0435\u0437 \u043E\u0442\u0432\u0451\u0440\u0442\u043A\u0438
      \u044D\u0442\u043E \u043D\u0435 \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C"
    voiceAnyTime: {fileID: 0}
    chance: 100
    showTime: 3
    type: 0
    isOneTime: 0
    hasBeen: 0
  - remark: "\u0418\u0448\u0430 \u043A\u0440\u0443\u0448\u0438\u0442\u044C! \u041D\u0435\u0442,
      \u0441\u0435\u0440\u044C\u0435\u0437\u043D\u043E, \u044F \u043D\u0435 \u0441\u043F\u0440\u0430\u0432\u043B\u044E\u0441\u044C
      \u0433\u043E\u043B\u044B\u043C\u0438 \u0440\u0443\u043A\u0430\u043C\u0438"
    voice: {fileID: 0}
    isMultiRemark: 1
    remarkAnyTime: "\u041C\u043D\u0435 \u043D\u0443\u0436\u0435\u043D \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442,
      \u0447\u0442\u043E\u0431\u044B \u0440\u0430\u0441\u043F\u0438\u043B\u0438\u0442\u044C
      \u044D\u0442\u043E"
    voiceAnyTime: {fileID: 0}
    chance: 100
    showTime: 3
    type: 2
    isOneTime: 0
    hasBeen: 0
  - remark: "\u0410\u0439! \u041D\u0435\u043F\u0440\u0438\u044F\u0442\u043D\u043E
      \u043A\u043E\u0433\u0434\u0430 \u043E\u0442\u0432\u0435\u0440\u0442\u043A\u0430
      \u0441\u043E\u0441\u043A\u0430\u043A\u0438\u0432\u0430\u0435\u0442 \u0438 \u043E\u0442\u0441\u0435\u043A\u0430\u0435\u0442
      \u043F\u0430\u043B\u0435\u0446!"
    voice: {fileID: 0}
    isMultiRemark: 1
    remarkAnyTime: "\u041C\u0438\u043D\u0443\u0441 \u0435\u0449\u0435 \u043F\u0430\u043B\u044C\u0447\u0438\u043A,
      \u043F\u0440\u0438\u043A\u0443\u043F\u0438\u0442\u044C \u0431\u044B \u043F\u0435\u0440\u0447\u0430\u0442\u043E\u043A,
      \u043F\u043E\u043A\u0430 \u0435\u0441\u0442\u044C, \u043D\u0430 \u0447\u0442\u043E
      \u0438\u0445 \u043D\u0430\u0434\u0435\u0442\u044C"
    voiceAnyTime: {fileID: 0}
    chance: 100
    showTime: 3
    type: 1
    isOneTime: 0
    hasBeen: 0
