    \u0434\u0430\u043B \u043F\u043E\u0441\u0435\u0432 \u0447\u0435\u043B\u043E\u0432\u0435\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u0431\u0435\u0437\u0440\u0430\u0437\u043B\u0438\u0447\u0438\u044F \u0438 \u0436\u0430\u0436\u0434\u044B
    \u043F\u043E\u0442\u0440\u0435\u0431\u043B\u0435\u043D\u0438\u044F: \u043D\u0430
    \u0440\u0443\u0438\u043D\u0430\u0445 \u043F\u0440\u0438\u0440\u043E\u0434\u044B
    \u0432\u043E\u0446\u0430\u0440\u0438\u043B\u0438\u0441\u044C \u0433\u043E\u043B\u043E\u0434,
    \u0436\u0430\u0436\u0434\u0430 \u0438 \u0445\u0432\u043E\u0440\u044C. \u0423\u0434\u0435\u043B
    \u043F\u043E\u0436\u0438\u043D\u0430\u044E\u0449\u0438\u0445 \u044D\u0442\u043E\u0442
    \u0443\u0440\u043E\u0436\u0430\u0439 \u043F\u043E\u0438\u0441\u0442\u0438\u043D\u0435
    \u043D\u0435\u0437\u0430\u0432\u0438\u0434\u0435\u043D..."
