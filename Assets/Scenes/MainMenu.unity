  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0421\u043F\u0438\u0441\u043E\u043A \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u043E\u0432:\n\n\u041D\u0430\u0441\u0442\u0430\u0432\u043D\u0438\u043A:
    \u0412\u0430\u043B\u0435\u043D\u0442\u0438\u043D \u0421\u0430\u0432\u0438\u043D\u043E\u0432\n\nTeam-leader,
    \u0433\u0435\u0439\u043C\u0434\u0438\u0437\u0430\u0439\u043D\u0435\u0440: \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440
    \u0413\u043E\u0440\u0435\u043B\u0438\u043A\n\nVision-holder, \u043D\u0430\u0440\u0440\u0430\u0442\u0438\u0432\u043D\u044B\u0439
    \u0434\u0438\u0437\u0430\u0439\u043D\u0435\u0440: \u0415\u043B\u0435\u043D\u0430
    \u041F\u0435\u0440\u0435\u0442\u043E\u043A\u0438\u043D\u0430\n\n\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0438:
    \u0410\u043B\u0435\u043A\u0441\u0430\u043D\u0434\u0440 \u041F\u0440\u0438\u043C\u0430\u043A,
    \u0410\u043D\u0434\u0440\u0435\u0439 \u041D\u0435\u043F\u0441\u043E\u0432\n\n3D
    \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A\u0438: \u0414\u0435\u043D\u0438\u0441
    \u0428\u0443\u043C\u0438\u043B\u043E\u0432, \u0410\u0440\u0442\u0443\u0440 \u041B\u0443\u043A\u043C\u0430\u043D,
    \u041A\u0441\u0435\u043D\u0438\u044F \u041F\u0430\u0433\u0430\n\n2D \u0445\u0443\u0434\u043E\u0436\u043D\u0438\u043A:
    \u0414\u0430\u0440\u044C\u044F \u041F\u0430\u0432\u043B\u0435\u043D\u043A\u043E\n\n\u0421\u0430\u0443\u043D\u0434-\u0434\u0438\u0437\u0430\u0439\u043D\u0435\u0440:
    \u041C\u0430\u0440\u0438\u043D\u0430 \u041A\u043E\u0442\u0435\u043D\u0435\u0432\u0430"
