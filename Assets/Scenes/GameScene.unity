    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[3].remark
      value: "\u0410\u0439! \u041D\u0435\u043F\u0440\u0438\u044F\u0442\u043D\u043E
        \u043A\u043E\u0433\u0434\u0430 \u043E\u0442\u0432\u0435\u0440\u0442\u043A\u0430
        \u0441\u043E\u0441\u043A\u0430\u043A\u0438\u0432\u0430\u0435\u0442 \u043F\u0440\u043E\u0442\u044B\u043A\u0430\u0435\u0442
        \u0440\u0443\u043A\u0443!"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[4].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[4].remark
      value: "\u041E! \u0415\u0441\u043B\u0438 \u043F\u0435\u0440\u0435\u043A\u0443\u0441\u0438\u0442\u044C
        \u0437\u0434\u0435\u0441\u044C \u0438 \u0437\u0434\u0435\u0441\u044C, \u043E\u043D\u0430
        \u043E\u0442\u0432\u0430\u043B\u0438\u0442\u0441\u044F! \u041C\u043E\u0436\u0435\u0442,
        \u0443 \u0420\u0430\u0445\u0443\u043B\u0430 \u043D\u0430\u0439\u0434\u0435\u0442\u0441\u044F
        \u0438\u043D\u0441\u0442\u0440\u0443\u043C\u0435\u043D\u0442?"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[5].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[5].remark
      value: "\u041A\u0445\u0435-\u043A\u0445\u0435\u2026 \u043C\u0435\u043D\u044F
        \u0441\u0435\u0439\u0447\u0430\u0441 \u0432\u044B\u0432\u0435\u0440\u043D\u0435\u0442!"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[6].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[6].remark
      value: "\u041D\u0430 \u043A\u0430\u043B\u0438\u0442\u043A\u0435 \u0443\u0432\u0435\u0441\u0438\u0441\u0442\u044B\u0439
        \u0437\u0430\u043C\u043E\u043A, \u0431\u0435\u0437 \u043A\u043B\u044E\u0447\u0430
        \u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u0442\u044C!"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[7].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[7].remark
      value: "\u0410 \u044D\u0442\u0430 \u0448\u0442\u0443\u043A\u0430 \u0438 \u043F\u0440\u0430\u0432\u0434\u0430
        \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442!"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[8].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[8].remark
      value: "\u201C\u042D\u0442\u043E \u0436\u0435\u2026 \u0435\u0441\u043B\u0438
        \u044F \u044D\u0442\u043E \u0441\u043E\u0431\u0435\u0440\u0443, \u0442\u043E
        \u043E\u0447\u0438\u0449\u0443 \u0432\u043E\u0434\u0443 \u0432 \u043D\u0430\u0448\u0435\u043C
        \u043F\u0440\u0443\u0434\u0443! \u0422\u043E\u043B\u044C\u043A\u043E \u043D\u0430\u0434\u043E
        \u043D\u0430\u0439\u0442\u0438 \u043F\u043E\u0434\u0445\u043E\u0434\u044F\u0449\u0438\u0435
        \u0434\u0435\u0442\u0430\u043B\u0438\u201D."
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[9].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[9].remark
      value: "\u0421\u043E\u0431\u0435\u0440\u0438\u0442\u0435 \u0432\u0441\u0435
        \u0434\u0435\u0442\u0430\u043B\u0438 \u0441\u043A\u0438\u043C\u043C\u0435\u0440\u0430
        \u0441 \u0447\u0435\u0440\u0442\u0435\u0436\u0430 \u0438 \u043F\u043E\u0434\u0430\u0440\u0438\u0442\u0435
        \u0441\u0432\u043E\u0435\u0439 \u0434\u0435\u0440\u0435\u0432\u043D\u0435
        \u0447\u0438\u0441\u0442\u0443\u044E \u0432\u043E\u0434\u0443"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[10].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[10].remark
      value: "\u041F\u0440\u0438\u0432\u0435\u0442, \u0434\u0443\u0440\u0430\u0446\u043A\u0430\u044F
        \u0434\u0435\u0442\u0430\u043B\u044C, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
        \u0434\u043E\u043B\u0436\u043D\u0430 \u043E\u0447\u0438\u0441\u0442\u0438\u0442\u044C
        \u0432\u043E\u0434\u0443 \u0434\u043B\u044F \u0434\u0443\u0440\u0430\u0446\u043A\u043E\u0439
        \u0434\u0435\u0440\u0435\u0432\u043D\u0438, \u0433\u0434\u0435 \u0436\u0438\u0432\u0435\u0442
        \u0434\u0443\u0440\u0430\u0446\u043A\u0430\u044F \u043C\u0430\u0442\u044C,
        \u0440\u043E\u0434\u0438\u0432\u0448\u0430\u044F \u0434\u0443\u0440\u0430\u0446\u043A\u0443\u044E
        \u043C\u0435\u043D\u044F!"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[11].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[11].remark
      value: "\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F \u0434\u0435\u0442\u0430\u043B\u044C!
        \u0422\u0435\u043F\u0435\u0440\u044C \u043D\u0430\u0434\u043E \u0432\u0441\u0435
        \u0441\u043E\u0431\u0440\u0430\u0442\u044C \u0432 \u043A\u0443\u0447\u0443!"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[12].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[12].remark
      value: "\u041C\u043D\u0435 \u043D\u0430\u0434\u043E \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C.
        \u041F\u0443\u0441\u0442\u044C\u2026 \u043F\u0443\u0441\u0442\u044C \u043C\u0430\u043C\u0430
        \u043E\u0442\u0434\u044B\u0445\u0430\u0435\u0442 \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[13].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[13].remark
      value: "\u0415\u0449\u0435 \u0440\u0430\u043D\u043E \u0438\u0434\u0442\u0438
        \u0434\u043E\u043C\u043E\u0439, \u043C\u043D\u0435 \u043D\u0430\u0434\u043E
        \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[14].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[14].remark
      value: "\u041A\u0430\u043A \u0436\u0435 \u0445\u043E\u0447\u0435\u0442\u0441\u044F
        \u0435\u0441\u0442\u044C!"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[15].chance
      value: 100
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[15].remark
      value: "\u0412\u043E \u0440\u0442\u0443 \u0432\u0441\u0435 \u043F\u0435\u0440\u0435\u0441\u043E\u0445\u043B\u043E\u2026"
      objectReference: {fileID: 0}
    - target: {fileID: 5941980546906322942, guid: ac309359e8a6a654b9602de6b7bbb0e0, type: 3}
      propertyPath: _remarks.Array.data[16].chance
      value: 100
