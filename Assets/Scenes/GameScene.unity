    - target: {fileID: 3661122085923481506, guid: fdfb45c76bba6e24487e03ecb8292cae, type: 3}
      propertyPath: m_Text
      value: "\u0427\u0438\u0441\u0442\u0430\u044F \u0432\u043E\u0434\u0430! \u0412\u0441\u0435
        \u0443\u0441\u0438\u043B\u0438\u044F, \u0432\u0441\u0435 \u0442\u0440\u0443\u0434\u044B
        \u043F\u0440\u0438\u0431\u043B\u0438\u0436\u0430\u043B\u0438 \u044D\u0442\u0443
        \u043C\u0438\u043D\u0443\u0442\u0443, \u043A\u043E\u0433\u0434\u0430 \u0434\u0435\u0440\u0435\u0432\u043D\u044F
        \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430 \u043F\u0438\u0442\u044C\u0435\u0432\u0443\u044E
        \u0432\u043E\u0434\u0443, \u043E\u0447\u0438\u0449\u0435\u043D\u043D\u0443\u044E
        \u043E\u0442 \u043E\u0442\u0440\u0430\u0432\u044B \u0411\u043E\u043B\u044C\u0448\u043E\u0439
        \u0421\u0432\u0430\u043B\u043A\u0438. \u0421\u0435\u0433\u043E\u0434\u043D\u044F
        \u043A\u0430\u0436\u0434\u044B\u0439 \u043F\u043E\u043B\u0443\u0447\u0438\u0442
        \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449\u0435, \u043A\u043E\u0442\u043E\u0440\u043E\u0435
        \u0432 \u0434\u0440\u0443\u0433\u043E\u043C \u043C\u0438\u0440\u0435 \u0432\u043E\u0437\u043D\u0438\u043A\u0430\u0435\u0442,
        \u0441\u0442\u043E\u0438\u0442 \u0442\u043E\u043B\u044C\u043A\u043E \u043F\u043E\u0432\u0435\u0440\u043D\u0443\u0442\u044C
        \u043A\u0440\u0430\u043D - c\u0442\u0430\u043A\u0430\u043D \u0432\u043E\u0434\u044B."
      objectReference: {fileID: 0}
